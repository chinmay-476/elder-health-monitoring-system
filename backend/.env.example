# Backend port
PORT=5001

# Use "production" after deployment
NODE_ENV=development

# Local MongoDB example. Replace with MongoDB Atlas in production.
MONGO_URI=mongodb://127.0.0.1:27017/elder-health-monitoring

# Replace with a long random secret
JWT_SECRET=replace_with_a_long_random_secret

# Allowed frontend URLs for CORS. Separate multiple URLs with commas.
CLIENT_URL=http://localhost:5173
